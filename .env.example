# Example environment variables for local development
# Copy this file to .env and edit values before running `docker compose up`.

# MySQL root password (used to initialize the database)
DB_ROOT_PASSWORD=Ynep21332133.
# Application database and user
DB_USER=payments
DB_PASSWORD=payments
# R2DBC connection string for the application (defaults to use the `db` service in compose)
SPRING_R2DBC_URL=r2dbc:mysql://root:Ynep21332133.@db:3306/payments?allowPublicKeyRetrieval=true&useSSL=false
# R2DBC / JDBC credentials (optional, kept in sync with DB_USER/DB_PASSWORD by default)
R2DBC_USERNAME=root
R2DBC_PASSWORD=Ynep21332133.
RDBMS_USERNAME=root
RDBMS_PASSWORD=Ynep21332133.

# If you want the app to point to a different DB host (e.g., host.docker.internal), set SPRING_R2DBC_URL accordingly
# SPRING_R2DBC_URL=r2dbc:mysql://root:yourpassword@host.docker.internal:3306/payments?allowPublicKeyRetrieval=true&useSSL=false
